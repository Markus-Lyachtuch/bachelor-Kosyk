@import '../../../app/styles/index.styl'

.sidebar-icon
    display flex
    flex-direction column
    align-items center
    gap .5rem
    cursor pointer
    text-decoration none

    @media screen and (max-width: sm)
        gap: 0

    &.active > *
        color var(--primary)
        fill var(--primary)
    
.sidebar-title
    color var(--black)
    font-weight 500
