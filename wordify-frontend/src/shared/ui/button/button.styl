@import "../../../app/styles/index.styl"

.btn
    border: none
    cursor pointer
    padding: .5rem 2rem

    &-trial
        cursor pointer
        width 11.25rem
        font-size: 1rem
        font-weight 600
        border-radius 20px
        padding .5rem 1.25rem
        transition background .2s
        background var(--yellow)

        @media (max-width: lg)
            width 10rem
            padding 8px 15px
            font-size 0.9rem
        @media (max-width: md)
            width 7rem
            padding 6px 12px

        &:hover
            background var(--yellow-light)

        


    &-auth
        font-weight: 500
        padding: 0.625rem
        border-radius: 5px
        font-size: inherit
        color: var(--white)
        transition: opacity .3s ease
        background: var(--primary-light)
        &:hover
            opacity: 0.8
    
    &-google
        width 100%
        gap: 0.25rem
        display: flex
        padding: 0.25rem
        color: #494949
        font-weight: 600
        font-size: 1.25rem
        border-radius: 5px
        align-items: center
        justify-content: center
        background: transparent
        transition: border .3s ease
        border: 2px solid rgba(0,0,0, 0.25)
        &:hover
            border: 2px solid var(--primary)


    &-primary
        font-weight: 600
        border-radius: 24px
        color: var(--white)
        background: var(--primary)
        transition: background .5s ease
        &:not(:disabled):hover
            background: var(--primary-light-2)
        
        &:disabled
            opacity .8
    
    &-outline
        font-weight: 600
        border-radius: 24px
        color: var(--primary)
        background: transparent
        border: 2px solid var(--primary)
        transition: background .5s ease, color .5s ease

        &-correct, &-incorrect
            border-radius: 24px
            background: transparent
            transition: all .5s ease

        &-correct
            border 2px solid var(--green)
            color: var(--green)
        
        &-incorrect
            border 2px solid var(--dark-red)
            color: var(--dark-red)

        &:hover
            background: var(--primary)
            color: var(--white)

    &-danger
        font-weight: 600
        border-radius: 24px
        color: var(--white)
        background: var(--dark-red)
        transition: opacity .5s ease
        &:hover
            opacity .7
    
    &-sort
        display: flex
        align-items: center
        justify-content: center
        background: #fff
        border: 1px solid #e0e0e0
        padding: 8px 16px
        border-radius: 20px
        font-size: 14px
        color: #333
        cursor: pointer
        width: 8.75rem
        gap: 8px
        box-shadow: 0 2px 5px rgba(0,0,0,0.2)
        transition: 0.2s


        &:hover
            background #f8f8f8
            border-color #ccc
    
    &-rounded
        background: var(--primary)
        position: relative
        border-radius: 50%
        padding: .75rem
        transition: background .5s ease
        &:hover
            background: var(--primary-light-2)
    
    &-ai
        gap: .5rem
        display flex
        font-weight: 600
        font-size: .875rem
        align-items: center
        color: var(--black)
        border-radius: 10px
        padding: .75rem 1.5rem
        background: var(--secondary)
        transition: background .5s ease
        box-shadow: var(--box-shadow-blurred)
        &:hover
            background: var(--secondary-light)

.plus-btn > h2
    line-height: 1.16375rem
    color: var(--white)
