.empty-state
    width: 100%
    height: 100%
    font-weight: 500

    & > div
        gap: .5rem
        
    &-description
        font-size: .875rem

    &-btn
        border: none
        cursor: pointer
        font-weight: 600
        color: var(--white)
        border-radius: 24px
        padding: .5rem 2rem
        background: var(--primary)
        transition: background .5s ease
        &:hover
            background: var(--primary-light-2)