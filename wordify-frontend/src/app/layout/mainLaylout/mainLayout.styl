@import '../../styles/index.styl'

.main-layout
    width 100%
    display: flex
    
    @media screen and (max-width: sm)
        flex-direction: column

    &-left
        z-index 5
        width 86px
        height 100%
        gap: 1.5rem
        display: flex
        overflow-y: auto
        font-size: .875rem
        align-items: center
        flex-direction: column
        padding: 3.4375rem 0
        box-shadow: var(--box-shadow)

        @media screen and (max-width: sm)
            width 100%
            height: 86px
            order: 2
            padding: 0 1rem
            flex-direction: row
            justify-content: center
            box-shadow: var(--vertical-box-shadow)

    &-right
        flex: 1
        overflow-y: auto
        padding: 0 2.75rem
        @media screen and (max-width: lg)
            padding: 0 1.5rem

        @media screen and (max-width: sm)
            order: 1
