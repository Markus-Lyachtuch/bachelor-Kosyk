@import '../../app/styles/index.styl'

.word-card
  display flex
  align-items stretch
  background #fff
  border-radius 24px
  padding 0.5rem
  margin 0
  box-shadow 0 4px 20px rgba(0, 0, 0, 0.3)
  gap 1.0625rem
  width 100%

  @media screen and (max-width: md)
    flex-direction column
    align-items flex-start
    padding 1.25rem
    gap 1rem

.word-card-img
  user-select: none
  width 12.5rem
  height 11.6875rem
  border-radius 20px
  object-fit cover
  flex-shrink 0
  
  @media screen and (max-width: xl)
    width 10rem
    height 10rem

  @media screen and (max-width: md)
    width 100%
    height 15rem

.word-card-content
  flex 1
  display flex
  flex-direction column
  justify-content space-between
  margin-right 1.25rem
  padding 0.4rem 0

  @media screen and (max-width: md)
    width 100%
    height auto
    margin-right 0
    padding 0
    gap 1.25rem

.content-top, .content-bottom
  display flex
  justify-content space-between
  align-items flex-start
  
  @media screen and (max-width: md)
    flex-direction column
    align-items flex-start
    gap 0.75rem

.content-top
  margin-top 0.25rem
  @media screen and (max-width: md)
    margin-top 0

.content-bottom
  align-items flex-end
  margin-bottom 0.2rem
  
  @media screen and (max-width: md)
    align-items flex-start
    margin-bottom 0
    width 100%

.title-group
  display flex
  align-items center
  gap 1.375rem
  margin-bottom 1rem
  
  @media screen and (max-width: md)
    margin-bottom 0.25rem

.card-title
  margin 0
  font-size 1.25rem
  font-weight 500

.card-level
  color #5F3DC4
  font-size 0.875rem
  font-weight 400

.card-count, .card-author
  font-size 0.875rem
  font-weight 400
  margin 0

.info-stats
  display flex
  gap 2.5rem
  font-weight 500
  font-size 0.9375rem
  padding-top 0.3125rem
  
  .stat-item p
    margin 0
    display inline-block
  
  @media screen and (max-width: md)
    padding-top 0

.stat-item
  display flex
  align-items center
  gap 0.3125rem

.star
  font-size 1.125rem 

.view-btn
  background #5e35b1
  color white
  border none
  width 11.375rem
  height 2.5rem
  border-radius 24px
  font-size 0.875rem
  font-weight 600
  cursor pointer
  transition 0.2s
  
  @media screen and (max-width: md)
    width 100%
    margin-top 0.5rem
  
  &:hover
    background #4527a0
    transform translateY(-1px)
    