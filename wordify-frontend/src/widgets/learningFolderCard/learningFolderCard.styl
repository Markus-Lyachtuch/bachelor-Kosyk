@import '../../app/styles/index.styl'

$lcard-purple = #5F3DC4
$lcard-shadow = 0 4px 12px rgba(0, 0, 0, 0.05)
$lcard-text-muted = #757575

.lcard-container
  flex 0 0 41.73vw
  display flex
  align-items center
  background #ffffff
  border-radius 24px
  padding 8px
  box-shadow $lcard-shadow
  border 1px solid #f0f0f0
  gap 20px
  box-sizing border-box
  scroll-snap-align start
  cursor pointer
  transition flex-basis 0.2s ease, padding 0.2s ease

  @media (max-width: xxl)
    flex 0 0 30rem

  @media (max-width: xl)
    flex 0 0 28rem
    gap 16px

  @media (max-width: lg)
    flex 0 0 calc(100vw - 5.375rem - 3rem - .9rem)
    border-radius 20px

  @media (max-width: md)
    flex 0 0 calc(100vw - 5.375rem - 3rem - .9rem)
    gap 12px
    padding 6px

  @media (max-width: sm)
    flex 0 0 calc(100vw - 3rem - .9rem)
    gap 10px
    .lcard-image-box
      flex 0 0 8rem
      height 6rem

.lcard-image-box
  flex 0 0 11.3125rem
  height 8.125rem
  border-radius 18px
  overflow hidden
  transition flex-basis 0.2s ease, height 0.2s ease
  
  img
    width 100%
    height 100%
    object-fit cover

.lcard-title-wrapper
  gap: .375rem

.lcard-info
  flex 1
  gap: 1.75rem 

  h4
    margin 0 0 4px 0
    font-size 1.1rem
    font-weight 600
    white-space nowrap
    overflow hidden
    text-overflow ellipsis
    
    @media (max-width: md)
      font-size 1rem

  .lcard-author
    font-size .875rem
    color rgba(0,0,0,.7)

.lcard-progress-wrapper
  gap: .625rem

  .lcard-progress-track
    height 6px
    background #f0f0f0
    border-radius 10px
    margin-bottom 8px

  .lcard-progress-fill
    height 100%
    background $lcard-purple
    border-radius 10px
    transition width 0.3s ease-out

  .lcard-status-text
    font-size .875rem
    color $lcard-text-muted
