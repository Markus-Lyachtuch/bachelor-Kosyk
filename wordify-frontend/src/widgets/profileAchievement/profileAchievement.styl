.profile-achievement-widget
    gap: 2rem
    border-radius: 24px
    background: var(--white)
    padding: .5rem 1rem .5rem .5rem
    box-shadow: 0 2px 10px 1px rgba(3, 3, 3, .1)

    &-icon-block
        height: 8.125rem
        border-radius: 24px
        flex: 0 1 11.3125rem
        background: var(--secondary)
    
    &-info
        flex: 1
        gap: .75rem

        &-progress
            font-size: 0.875rem
            color: rgba(0,0,0,0.7)
