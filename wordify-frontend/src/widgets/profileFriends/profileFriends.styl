.profile-friends
    padding .75rem 1.5rem 1.5rem 1.5rem
    border-radius: 24px
    box-shadow: 0 0 20px 0 rgba(0,0,0,.25)

    &-piece
        gap: .5rem
        padding-top: .75rem
        padding-bottom: .5rem
        border-bottom: 1px solid var(--extra-light-grey)

        &:last-child
            border-bottom: none

        & > button
            padding: .5rem
            font-size: .75rem
            & > a
                color: var(--white)
                text-decoration: none

        &-name
            font-weight: 500
            white-space: nowrap

            &-and-avatar
                gap: .625rem

        &-avatar
            height: 25px
            flex: 0 0 25px
            position relative
            border-radius: 50%
            color: var(--white)
            background: var(--primary)
            text-transform: capitalize