@import '../../app/styles/index.styl'

.full-set-page
    &-container
        display flex
        width 100%
        margin 40px auto
        padding 30px 16px 0px 16px
        gap 40px
        box-sizing border-box
  
        @media (max-width: lg)
            flex-direction column

    &-btn
        display flex
        align-items center
        justify-content center
        gap 10px
        flex 1 
        min-width 160px
        height 54px 
        padding 0 20px
        border-radius 14px
        border none
        font-size 16px
        font-weight 600
        cursor pointer
        box-shadow var(--box-shadow-light)
        transition all 0.2s ease
        box-sizing border-box
        transition: background .3s ease-in-out

        &:disabled
            cursor: not-allowed
            & .icon
                fill var(--grey)

        &:not(:disabled):hover
            background: var(--secondary)

        @media (max-width: sm)
            padding: .5rem 0

        &:active
            transform translateY(1px)

.main-content
  flex 1
  width 100%

.header
  h1
    font-size 2rem
    font-weight 600
    margin-bottom 20px
    @media (max-width: sm)
      font-size 1.6rem

.button-group
  display flex
  gap 20px 
  margin-bottom 50px
  width 100%
  max-width 800px 

  @media (max-width: sm)
    flex-direction column
    gap 1.5rem

.stats-bar
  display flex
  justify-content space-between
  align-items center
  margin-bottom 20px
  flex-wrap wrap
  gap 15px

  .info
    display flex
    align-items center

  .word-count
    font-size 1.5rem
    font-weight 600
    margin-right 15px
    @media (max-width: sm)
      font-size 1.2rem

  .meta
    display flex
    gap 15px
    font-weight 500
    span
      display flex
      align-items center
      gap 6px

.author-row
  display flex
  justify-content space-between
  align-items center
  padding 30px 0
  border-top 1px solid #d1d1d1 
  border-bottom 1px solid #d1d1d1
  margin 30px 0
  gap 20px
  flex-wrap wrap

  @media (max-width: md)
    flex-direction column
    align-items flex-start

  .author-info
    display flex
    align-items center
    gap 16px
    flex-shrink 0
    
    .avatar
      width 50px
      height 50px
      background var(--primary)
      color var(--white)
      border-radius 50%
      display flex
      align-items center
      justify-content center
      font-weight 600
      font-size 1.2rem
      
    .text
      .name
        margin 0
        font-size 0.85rem
        font-weight 500
        strong
          display block 
          font-size 1.05rem
          margin-top 2px
      .date
        margin 2px 0 0 0
        font-size 0.8rem

.action-buttons
  display flex
  align-items center
  gap 12px
  flex-wrap wrap

  @media (max-width: md)
    width 100%
    justify-content flex-start

  .btn-icon
    background #fff
    border none
    height 40px
    width 10rem
    padding 0 16px
    display flex
    align-items center
    justify-content center
    gap 8px
    border-radius 12px
    cursor pointer
    font-size 0.9rem
    font-weight 600
    box-shadow var(--box-shadow-blurred)
    transition all 0.2s ease
    flex-shrink 0

    @media (max-width: lg)
      width auto
      font-size 0.8rem
    
    @media (max-width: md)
      width auto
      flex 1
      min-width 90px
      font-size 0.8rem

    &:hover
      transform translateY(-1px)

  .btn-icon-saved
    border 1px solid var(--primary)
    color var(--primary)

  .btn-more
    background var(--white)
    border none
    width 40px
    height 40px
    border-radius 12px
    display flex
    align-items center
    justify-content center
    box-shadow var(--box-shadow-blurred)
    cursor pointer
    font-size 1.2rem
    transition all 0.2s ease
    flex-shrink 0

    .icon
      transition transform 0.2s ease
      transform-origin center
      transform-box fill-box

    &:hover
      transform translateY(-2px)
      background #fafafa
      .icon
        transform rotate(90deg)
      

.word-list
  display flex
  flex-direction column
  gap 20px
  margin-top 20px
