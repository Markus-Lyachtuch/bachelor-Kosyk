black = #000

.study-page
    width: 100%
    height: 100%

    &-pronunciation
        &-block
            gap: 1rem

    &-pronunciation-practice
        width 100%
        gap: 5.4375rem
        padding: 5rem 0
        max-width: 37.5rem

        &-block
            width 100%
            padding: 1.25rem
            border-radius: 15px
            box-shadow: 0px 0px 10px rgba(black, 0.25)
            gap: 0.5rem
            & > h2
                text-transform: capitalize

    &-phonetic
        gap: 0.25rem
        &-container
            gap: 1rem

    &-word
        font-size: 1.25rem

    &-word-info-container
        margin-top: 0.75rem

    &-meaning-text
        font-size: 0.875rem
        color: var(--primary)

    &-info
        gap: 0.5rem
